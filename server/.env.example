PORT=5000
MONGO_URI=mongodb://localhost:27017/telemedicine
JWT_SECRET=replace-with-a-strong-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Staff account creation is disabled by default on public deployments.
# Set ALLOW_PUBLIC_STAFF_REGISTRATION=true only for controlled testing.
ALLOW_PUBLIC_STAFF_REGISTRATION=false
STAFF_BOOTSTRAP_KEY=replace-with-a-strong-bootstrap-key

# Optional WebRTC ICE configuration
# Leave TURN_* empty to fall back to STUN-only mode for local testing.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=turn:your-turn-host:3478?transport=udp,turn:your-turn-host:3478?transport=tcp
TURN_USERNAME=replace-with-turn-username
TURN_CREDENTIAL=replace-with-turn-password
